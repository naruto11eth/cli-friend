{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CLI Friend",
  "version": "0.1.0",
  "identifier": "eth.naruto11.clifriend",
  "build": {
    "frontendDist": "../src",
    "beforeBuildCommand": "bash scripts/build-stt.sh"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CLI Friend",
        "width": 380,
        "height": 460,
        "minWidth": 380,
        "minHeight": 240,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true,
        "shadow": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/cli-friend-stt"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Tiny Vim + CLI cheatsheet",
    "longDescription": "A small always-on-top menu-bar popup that answers plain-English questions about Vim keyboard shortcuts and modern CLI tools."
  }
}
